# 障碍物检测服务定义
# 请求参数
# 无参数，直接使用当前激光雷达数据

---
# 响应参数
bool success           # 是否成功
string message         # 返回消息
float32 safe_direction # 安全方向 (度，0为正前方，正数为左转，负数为右转)
float32 min_distance   # 最小障碍物距离 (米)
string[] sector_ranges # 扇区角度范围 (如["0-45°", "45-90°", ...])
bool[] has_obstacle    # 是否有障碍物 (对应每个扇区)
